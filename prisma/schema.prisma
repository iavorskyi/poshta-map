generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Postman {
  id             Int            @id @default(autoincrement())
  name           String
  rounds         Round[]
  addressRounds  AddressRound[]
  pensioners     Pensioner[]
}

model Pensioner {
  id                Int              @id @default(autoincrement())
  fullName          String
  buildingId        Int
  apartment         String?
  phone             String?
  passportNumber    String?
  pensionPaymentDay Int
  postmanId         Int?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  building          Building         @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  postman           Postman?         @relation(fields: [postmanId], references: [id], onDelete: SetNull)
  currentPayments   CurrentPayment[]

  @@index([buildingId])
  @@index([postmanId])
}

model Payment {
  id              Int              @id @default(autoincrement())
  name            String
  code            String           @unique
  currentPayments CurrentPayment[]
}

model Round {
  id              Int              @id @default(autoincrement())
  date            DateTime
  postmanId       Int?
  notes           String?
  closedAt        DateTime?
  createdAt       DateTime         @default(now())
  postman         Postman?         @relation(fields: [postmanId], references: [id], onDelete: SetNull)
  currentPayments CurrentPayment[]
}

model Building {
  id            Int                    @id @default(autoincrement())
  street        String
  number        String
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  entrances     Entrance[]
  pensioners    Pensioner[]
  addressRounds AddressRoundBuilding[]

  @@unique([street, number])
  @@index([street])
}

model Entrance {
  id         Int      @id @default(autoincrement())
  buildingId Int
  number     Int
  aptFrom    Int?
  aptTo      Int?
  notes      String?
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([buildingId, number])
  @@index([buildingId])
}

model AddressRound {
  id        Int                    @id @default(autoincrement())
  date      DateTime
  postmanId Int?
  notes     String?
  closedAt  DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  postman   Postman?               @relation(fields: [postmanId], references: [id], onDelete: SetNull)
  items     AddressRoundBuilding[]
}

model AddressRoundBuilding {
  id         Int          @id @default(autoincrement())
  roundId    Int
  buildingId Int
  notes      String?
  done       Boolean      @default(false)
  position   Int          @default(0)
  createdAt  DateTime     @default(now())
  round      AddressRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  building   Building     @relation(fields: [buildingId], references: [id], onDelete: Restrict)

  @@unique([roundId, buildingId])
  @@index([roundId])
  @@index([buildingId])
}

model CurrentPayment {
  id          Int       @id @default(autoincrement())
  roundId     Int?
  pensionerId Int
  paymentId   Int
  date        DateTime
  amount      Float
  isPaid      Boolean   @default(false)
  round       Round?    @relation(fields: [roundId], references: [id], onDelete: SetNull)
  pensioner   Pensioner @relation(fields: [pensionerId], references: [id], onDelete: Cascade)
  payment     Payment   @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([date])
  @@index([pensionerId, date])
}
